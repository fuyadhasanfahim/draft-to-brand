# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit real secrets.

# --- SMTP (required — powers the /contact form) ---------------------------
# Any SMTP provider works. For Gmail, SMTP_PASS must be a 16-character
# App Password (https://myaccount.google.com/apppasswords), not your login password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="you@example.com"
SMTP_PASS="your-smtp-app-password"
# Optional — "Name <email@domain>" sender header. Falls back to SMTP_USER if unset.
SMTP_FROM="Draft to Brand <noreply@drafttobrand.com>"

# --- MongoDB (required — stores /tools/brand-audit-checklist submissions) --
# Create a free cluster at https://www.mongodb.com/cloud/atlas, then paste its
# connection string here. Without this set, the audit tool still works for
# visitors — results just won't be saved.
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/drafttobrand?retryWrites=true&w=majority"

# --- Analytics (optional — omit to disable) --------------------------------
# NEXT_PUBLIC_* vars are exposed to the browser bundle. Never put secrets here.
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_META_PIXEL_ID="000000000000000"

# --- Vercel (auto-managed) -------------------------------------------------
# VERCEL_OIDC_TOKEN is written automatically by `vercel env pull` / `vercel link`.
# Do not set this manually — the app does not read it.
