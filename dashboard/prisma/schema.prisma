// Draft To Brand — Agency OS
// Phase 0 schema. Better Auth tables stay verbatim; agency identity is layered on top.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Better Auth — DO NOT rename, customize, or attach business logic.
// Auth identity only. Agency-level data lives on Member and downstream models.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  // Bridge into agency identity (1 auth user → many memberships across orgs)
  memberships           Member[]
  userPermissions       UserPermission[]
  auditLogs             AuditLog[]
  createdInvitations    Invitation[]     @relation("InvitationCreatedBy")
  createdCompanies      Company[]        @relation("CompanyCreatedBy")
  createdContacts       Contact[]        @relation("ContactCreatedBy")
  createdNotes          Note[]           @relation("NoteCreatedBy")
  createdIndustries     Industry[]       @relation("IndustryCreatedBy")
  createdCompanySizes   CompanySize[]    @relation("CompanySizeCreatedBy")
  createdLeadSources    LeadSource[]     @relation("LeadSourceCreatedBy")
  createdLeads          Lead[]           @relation("LeadCreatedBy")
  createdLeadActivities LeadActivity[]   @relation("LeadActivityCreatedBy")
  createdEmailCampaigns EmailCampaign[]  @relation("EmailCampaignCreatedBy")
  createdEmailSequences EmailSequence[]  @relation("EmailSequenceCreatedBy")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ─────────────────────────────────────────────────────────────────────────────
// Agency identity & org graph
// Structure: Organization → Branch → Department → Team → Member
// Designed so multi-org / multi-branch / multi-team can scale without redesign.
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches       Branch[]
  departments    Department[]
  teams          Team[]
  members        Member[]
  roles          Role[]
  invitations    Invitation[]
  auditLogs      AuditLog[]
  companies      Company[]
  contacts       Contact[]
  tags           Tag[]
  notes          Note[]
  industries     Industry[]
  companySizes   CompanySize[]
  leadSources    LeadSource[]
  pipelines      Pipeline[]
  leads          Lead[]
  leadActivities LeadActivity[]
  clients        Client[]
  emailCampaigns EmailCampaign[]
  emailSequences EmailSequence[]
  suppressions   SuppressionList[]

  @@index([slug])
  @@map("organization")
}

model Branch {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String
  address        String?
  city           String?
  country        String?
  isHeadquarter  Boolean   @default(false)
  archivedAt     DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departments  Department[]
  teams        Team[]
  members      Member[]
  invitations  Invitation[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("branch")
}

model Department {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String?
  name           String
  slug           String
  description    String?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  teams        Team[]
  members      Member[]
  invitations  Invitation[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([branchId])
  @@map("department")
}

model Team {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String?
  departmentId   String?
  name           String
  slug           String
  description    String?
  teamLeadId     String?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  members      Member[]
  invitations  Invitation[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([departmentId])
  @@map("team")
}

// Member = the agency employee profile bound to an auth User in a given Organization.
// All HR-shaped business logic in future phases should hang off Member, never off User.
enum MemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
  ARCHIVED
}

model Member {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  branchId       String?
  departmentId   String?
  teamId         String?
  roleId         String
  status         MemberStatus @default(ACTIVE)
  jobTitle       String?
  employeeCode   String?
  joinedAt       DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  team           Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  role           Role         @relation(fields: [roleId], references: [id])
  ownedCompanies Company[]    @relation("CompanyOwner")
  ownedLeads     Lead[]       @relation("LeadOwner")
  ownedClients   Client[]     @relation("ClientOwner")

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([branchId])
  @@index([departmentId])
  @@index([teamId])
  @@index([roleId])
  @@map("member")
}

// ─────────────────────────────────────────────────────────────────────────────
// Roles & Permissions
// Roles are database-driven and per-organization. System roles (Owner, Admin…)
// are seeded but admins can create unlimited custom roles later.
// Permissions are dotted keys (e.g. "users.view"). Effective permissions =
// (role permissions ∪ user-granted) ∖ (user-denied overrides).
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  isSystem       Boolean  @default(false) // Owner/Admin/etc — not deletable
  priority       Int      @default(0) // for UI ordering & tie-breaks
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members         Member[]
  rolePermissions RolePermission[]
  invitations     Invitation[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("role")
}

model Permission {
  id          String   @id @default(cuid())
  // Global registry keyed by dotted slug, e.g. "users.view", "roles.manage"
  key         String   @unique
  resource    String // "users", "roles", "teams", …
  action      String // "view", "create", "edit", "delete", "manage"
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([resource])
  @@map("permission")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@map("role_permission")
}

// Direct user-level grant or deny. `effect = DENY` always wins over role grant.
enum PermissionEffect {
  ALLOW
  DENY
}

model UserPermission {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  permissionId   String
  effect         PermissionEffect @default(ALLOW)
  reason         String?
  createdAt      DateTime         @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, permissionId])
  @@index([userId, organizationId])
  @@map("user_permission")
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit log — append-only operational trail. Every mutation should write one.
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  actorUserId    String?
  action         String // "member.invited", "role.updated", …
  resource       String // "member", "role", "branch", …
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId])
  @@index([resource, resourceId])
  @@map("audit_log")
}

// ─────────────────────────────────────────────────────────────────────────────
// Invitations — invitation-only signup gate.
// One pending invitation per (organization, email). Token is the secret used
// in the invite link; signup is allowed only when a PENDING, non-expired
// invitation exists for the email being registered.
// ─────────────────────────────────────────────────────────────────────────────

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
  DELETED
}

model Invitation {
  id             String           @id @default(cuid())
  email          String
  recipientName  String?
  token          String           @unique
  organizationId String
  roleId         String
  branchId       String?
  departmentId   String?
  teamId         String?
  // Optional direct-permission overrides applied on accept (array of PermissionKey).
  permissions    Json?
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  acceptedAt     DateTime?
  deletedAt      DateTime?
  createdById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("InvitationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@index([email])
  @@index([organizationId])
  @@index([status])
  @@map("invitation")
}

// ─────────────────────────────────────────────────────────────────────────────
// Email delivery log — append-only ledger that powers every rate-limit,
// cooldown, lockout, and one-shot check across the auth surface.
// One row per "event"; policies compute by counting + ordering on the index.
// ─────────────────────────────────────────────────────────────────────────────

enum EmailDeliveryScope {
  // Send attempts (count + last-row time → window cap + cooldown)
  VERIFICATION_OTP_SENT
  INVITATION_SENT
  PASSWORD_RESET_SENT
  WELCOME_SENT
  // Verification *failures* (count in 15-min window → lockout)
  VERIFICATION_OTP_FAILED
}

model EmailDeliveryLog {
  id         String             @id @default(cuid())
  // Identifier we throttle on. For per-user scopes this is the user's email,
  // lowercased; for per-invitation scopes we use `invitation:<id>` so that
  // resending the same invite doesn't collide with the recipient's other
  // pending invites.
  identifier String
  scope      EmailDeliveryScope
  // Optional metadata for forensics (request id, IP, user agent hash, etc).
  metadata   Json?
  createdAt  DateTime           @default(now())

  @@index([identifier, scope, createdAt])
  @@map("email_delivery_log")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2A — Companies & Contacts foundation.
// Every future module (Leads, Deals, Pipelines, Projects, Followups,
// WhatsApp, Campaigns, AI) attaches to these two roots.
// All records are organization-scoped; soft-delete via `archivedAt`.
// ─────────────────────────────────────────────────────────────────────────────

enum CompanyStatus {
  ACTIVE
  PROSPECT
  ARCHIVED
}

model Company {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  slug           String
  website        String?
  description    String?
  status         CompanyStatus @default(ACTIVE)
  city           String?
  address        String?
  phone          String?
  email          String?

  // Phase 2A.5 — reference-data FKs (replaced free-text industry/size/country).
  industryId    String?
  countryId     String?
  companySizeId String?
  leadSourceId  String?

  // Phase 2A.5 — workflow relations.
  ownerId          String? // Member who owns this account in the CRM workflow.
  primaryContactId String? // The "main POC" — a Contact on this company (or unset).

  archivedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation("CompanyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  industry       Industry?    @relation(fields: [industryId], references: [id], onDelete: SetNull)
  country        Country?     @relation(fields: [countryId], references: [id], onDelete: SetNull)
  companySize    CompanySize? @relation(fields: [companySizeId], references: [id], onDelete: SetNull)
  leadSource     LeadSource?  @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  owner          Member?      @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  primaryContact Contact?     @relation("CompanyPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)
  contacts        Contact[]        @relation("CompanyContacts")
  notes           Note[]
  tags            CompanyTag[]
  leads           Lead[]
  client          Client?
  emailRecipients EmailRecipient[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, archivedAt])
  @@index([industryId])
  @@index([countryId])
  @@index([companySizeId])
  @@index([leadSourceId])
  @@index([ownerId])
  @@index([primaryContactId])
  @@map("company")
}

enum ContactStatus {
  ACTIVE
  ARCHIVED
}

model Contact {
  id             String        @id @default(cuid())
  organizationId String
  companyId      String?
  firstName      String
  lastName       String
  email          String?
  phone          String?
  jobTitle       String?
  linkedinUrl    String?
  // Free-form inline notes on the contact card (distinct from the Note model,
  // which is a first-class timeline-style record). Use this for short personal
  // context the user wants visible without opening the Notes section.
  notes          String?
  status         ContactStatus @default(ACTIVE)
  archivedAt     DateTime?
  createdById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation("CompanyContacts", fields: [companyId], references: [id], onDelete: SetNull)
  primaryOf    Company[]    @relation("CompanyPrimaryContact")
  createdBy    User?        @relation("ContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  noteEntries  Note[]
  tags         ContactTag[]
  leads        Lead[]
  emailRecipients EmailRecipient[]

  @@index([organizationId])
  @@index([organizationId, companyId])
  @@index([organizationId, status])
  @@index([organizationId, archivedAt])
  @@map("contact")
}

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  // Hex color; UI renders chip with this color tinted to fit the design system.
  color          String   @default("#6b6e6e")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companies    CompanyTag[]
  contacts     ContactTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("tag")
}

model CompanyTag {
  companyId String
  tagId     String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([companyId, tagId])
  @@index([tagId])
  @@map("company_tag")
}

model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
  @@map("contact_tag")
}

model Note {
  id             String   @id @default(cuid())
  organizationId String
  companyId      String?
  contactId      String?
  content        String   @db.Text
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([companyId])
  @@index([contactId])
  @@map("note")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2A.5 — Reference data foundation.
// Country is global (system-managed, ISO 3166-1). Industry/CompanySize/
// LeadSource are per-organization dynamic taxonomies admins curate from
// Settings. Every future CRM entity (Leads, Pipelines, Deals, Campaigns)
// will attach to these so terminology stays consistent.
// ─────────────────────────────────────────────────────────────────────────────

model Country {
  id        String   @id @default(cuid())
  name      String
  iso2      String   @unique
  iso3      String   @unique
  phoneCode String
  createdAt DateTime @default(now())

  companies Company[]

  @@index([name])
  @@map("country")
}

model Industry {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String
  isActive       Boolean   @default(true)
  archivedAt     DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("IndustryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  companies    Company[]

  @@unique([organizationId, slug])
  @@index([organizationId, isActive])
  @@map("industry")
}

model CompanySize {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  archivedAt     DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("CompanySizeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  companies    Company[]

  @@unique([organizationId, slug])
  @@index([organizationId, isActive, sortOrder])
  @@map("company_size")
}

model LeadSource {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String
  color          String    @default("#6b6e6e")
  isActive       Boolean   @default(true)
  archivedAt     DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("LeadSourceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  companies    Company[]
  leads        Lead[]

  @@unique([organizationId, slug])
  @@index([organizationId, isActive])
  @@map("lead_source")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2B — Lead Management foundation.
// Pipelines + Stages model the sales workflow. A Lead is an active sales
// opportunity that walks the stages of a pipeline. LeadActivity is an
// append-only timeline of state changes (stage moves, owner changes, notes).
// Every record is organization-scoped; soft-delete via `archivedAt`.
// ─────────────────────────────────────────────────────────────────────────────

enum LeadStatus {
  OPEN
  WON
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Pipeline-stage terminal flag. `OPEN` stages keep the Lead alive; reaching
// a `WON` or `LOST` stage closes the Lead with the matching status. Derived
// at write time — there's no manual status dropdown on the Lead form.
enum StageOutcome {
  OPEN
  WON
  LOST
}

// Fixed currency allowlist for monetary fields. Free-text codes were
// error-prone (typos, lowercase, ISO 4217 codes we don't actually support).
enum Currency {
  USD
  EUR
  GBP
  AUD
  CAD
  SGD
  AED
  BDT
}

model Pipeline {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  isDefault      Boolean   @default(false)
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  leads        Lead[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, archivedAt])
  @@map("pipeline")
}

model PipelineStage {
  id             String   @id @default(cuid())
  pipelineId     String
  name           String
  slug           String
  color          String   @default("#6b6e6e")
  sortOrder      Int      @default(0)
  // 0–100; how confident we are a Lead in this stage will close-won.
  winProbability Int      @default(0)
  // Marks this stage as terminal (WON / LOST) so Lead.status can be derived
  // from it. Non-terminal stages keep the lead OPEN.
  outcome        StageOutcome @default(OPEN)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads    Lead[]

  @@unique([pipelineId, slug])
  @@index([pipelineId, sortOrder])
  @@map("pipeline_stage")
}

model Lead {
  id                String       @id @default(cuid())
  organizationId    String
  title             String
  companyId         String?
  contactId         String?
  leadSourceId      String?
  ownerId           String? // Member id
  pipelineId        String
  stageId           String
  status            LeadStatus   @default(OPEN)
  priority          LeadPriority @default(MEDIUM)
  estimatedValue    Decimal?     @db.Decimal(14, 2)
  currency          Currency?
  expectedCloseDate DateTime?
  description       String?
  archivedAt        DateTime?
  createdById       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  leadSource   LeadSource?    @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  owner        Member?        @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  pipeline     Pipeline       @relation(fields: [pipelineId], references: [id])
  stage        PipelineStage  @relation(fields: [stageId], references: [id])
  createdBy    User?          @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  activities   LeadActivity[]
  client       Client?
  emailRecipients EmailRecipient[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, archivedAt])
  @@index([pipelineId, stageId])
  @@index([companyId])
  @@index([contactId])
  @@index([ownerId])
  @@index([leadSourceId])
  @@map("lead")
}

model LeadActivity {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String
  // e.g. "lead.created", "stage.changed", "owner.changed", "note.added"
  type           String
  message        String?
  metadata       Json?
  createdById    String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("LeadActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@index([organizationId, createdAt])
  @@map("lead_activity")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2E — Client foundation.
// A Client is the post-sale relationship — the paying customer that future
// modules (Projects, Invoices, Contracts, Portal access) will attach to.
// Strict 1:1 with Company: a Company has at most one Client record. Created
// either by converting a WON Lead or directly via /dashboard/clients.
// ─────────────────────────────────────────────────────────────────────────────

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model Client {
  id               String           @id @default(cuid())
  organizationId   String
  // 1:1 with Company. The unique constraint enforces "one Client per Company".
  companyId        String           @unique
  // Set only when this Client was converted from a Lead. Unique so a Lead
  // can only ever produce one Client.
  leadId           String?          @unique
  ownerId          String?
  status           ClientStatus     @default(ACTIVE)
  onboardingStatus OnboardingStatus @default(NOT_STARTED)
  startDate        DateTime?
  notes            String?          @db.Text
  archivedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId],      references: [id])
  lead         Lead?        @relation(fields: [leadId],         references: [id], onDelete: SetNull)
  owner        Member?      @relation("ClientOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, archivedAt])
  @@index([ownerId])
  @@map("client")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3A — Cold Email Campaign foundation.
// An EmailCampaign is a one-off cold-email blast: a subject + body sent to a
// set of recipients drawn from existing Contacts and/or Leads. EmailRecipient
// denormalizes the address/name (so a later contact edit can't rewrite history)
// and tracks per-recipient delivery state. EmailEvent is an append-only timeline
// of delivery signals (sent/opened/clicked/replied/bounced) powering analytics.
//
// FOUNDATION ONLY: there is NO real sending, no Resend integration, no
// scheduling, no sequences, no inbox. Status + events are the data model that a
// future sending/tracking phase will write into. Everything is org-scoped via
// the parent campaign; soft-delete via `archivedAt` on the campaign.
// ─────────────────────────────────────────────────────────────────────────────

enum EmailCampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

// Furthest delivery state reached for a recipient. Advances monotonically in
// the intended happy path (PENDING → SENT → OPENED → CLICKED → REPLIED); a
// hard BOUNCED is terminal. Timestamps below record the first time each signal
// fired, so analytics stay accurate even after the status advances further.
enum EmailRecipientStatus {
  PENDING
  SENT
  OPENED
  CLICKED
  REPLIED
  BOUNCED
}

enum EmailEventType {
  SENT
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  // Phase 3 — a sequence followup email was dispatched to this recipient.
  FOLLOWUP_SENT
}

model EmailCampaign {
  id             String              @id @default(cuid())
  organizationId String
  name           String
  subject        String
  body           String              @db.Text
  // Sender identity overrides (Phase 2A). `fromName` becomes the display name
  // on the From header; `replyTo` overrides where replies route. Both optional —
  // fall back to the workspace brand defaults (EMAIL_CONFIG) when unset.
  fromName       String?
  replyTo        String?
  // Phase 3 — optional followup sequence. When set, recipients are enrolled
  // into this sequence at send time. SetNull so deleting a sequence doesn't
  // delete the campaign.
  sequenceId     String?
  status         EmailCampaignStatus @default(DRAFT)
  archivedAt     DateTime?
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?            @relation("EmailCampaignCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  sequence     EmailSequence?   @relation(fields: [sequenceId], references: [id], onDelete: SetNull)
  recipients   EmailRecipient[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, archivedAt])
  @@index([sequenceId])
  @@map("email_campaign")
}

model EmailRecipient {
  id         String               @id @default(cuid())
  campaignId String
  // Optional provenance — which CRM record this recipient was selected from.
  // SetNull so deleting/archiving the source record doesn't erase send history.
  leadId     String?
  contactId  String?
  // Resolved server-side from the source Contact→Company or Lead→Company at
  // add-time (never trusted from the client). Powers future per-company
  // reporting (open/reply rate by company). SetNull keeps history if the
  // company is later removed.
  companyId  String?
  // Denormalized address + name captured at add-time (history is immutable).
  email      String
  firstName  String?
  lastName   String?
  status     EmailRecipientStatus @default(PENDING)
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  repliedAt  DateTime?
  bouncedAt  DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  campaign    EmailCampaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead        Lead?                      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact     Contact?                   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company     Company?                   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  events      EmailEvent[]
  enrollments EmailSequenceEnrollment[]

  @@index([campaignId])
  @@index([campaignId, status])
  @@index([leadId])
  @@index([contactId])
  @@index([companyId])
  @@map("email_recipient")
}

model EmailEvent {
  id          String         @id @default(cuid())
  recipientId String
  type        EmailEventType
  metadata    Json?
  createdAt   DateTime       @default(now())

  recipient EmailRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
  @@map("email_event")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3 — Followup Sequences.
// A reusable EmailSequence is an ordered list of EmailSequenceStep followups.
// A campaign attaches one sequence; at send time each sent recipient gets an
// EmailSequenceEnrollment. A scheduler (poll-based, queue-ready) walks ACTIVE
// enrollments whose nextRunAt is due, evaluates the step's condition against
// the recipient's tracking state, and sends the followup via the existing email
// stack — recording a FOLLOWUP_SENT EmailEvent. Built on the campaign/recipient
// /event models; NOT a generic workflow builder.
// ─────────────────────────────────────────────────────────────────────────────

// Gate deciding whether a step's followup is sent for a given recipient.
enum SequenceStepCondition {
  ALWAYS              // always send
  NOT_OPENED          // openedAt IS NULL
  OPENED_NOT_CLICKED  // openedAt IS NOT NULL AND clickedAt IS NULL
  CLICKED_NOT_REPLIED // clickedAt IS NOT NULL AND repliedAt IS NULL
}

enum SequenceEnrollmentStatus {
  ACTIVE     // walking the steps
  PAUSED     // manually held (or sequence paused)
  COMPLETED  // ran out of steps
  STOPPED    // halted early (recipient replied/bounced)
}

model EmailSequence {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  // Activate / Pause toggle. Inactive sequences don't advance enrollments.
  isActive       Boolean   @default(true)
  // Soft-delete (codebase convention) — "Archive".
  archivedAt     DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?                     @relation("EmailSequenceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  steps        EmailSequenceStep[]
  enrollments  EmailSequenceEnrollment[]
  campaigns    EmailCampaign[]

  @@index([organizationId])
  @@index([organizationId, archivedAt])
  @@map("email_sequence")
}

model EmailSequenceStep {
  id         String                @id @default(cuid())
  sequenceId String
  // 1-based position in the sequence (ordering).
  stepNumber Int
  // Days after enrollment (campaign send) this step fires. e.g. 0, 3, 7, 14.
  delayDays  Int                   @default(0)
  subject    String
  body       String                @db.Text
  condition  SequenceStepCondition @default(ALWAYS)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, stepNumber])
  @@index([sequenceId, stepNumber])
  @@map("email_sequence_step")
}

model EmailSequenceEnrollment {
  id          String                   @id @default(cuid())
  sequenceId  String
  recipientId String
  // Zero-based pointer into the ordered steps: the index of the NEXT step to run.
  currentStep Int                      @default(0)
  status      SequenceEnrollmentStatus @default(ACTIVE)
  // When the next step is due. The scheduler polls on (status, nextRunAt).
  nextRunAt   DateTime?
  // Production hardening — scheduler claim lock. A run atomically sets lockedAt
  // before processing so a concurrent run can't double-send the same step.
  // Cleared after processing; a stale lock (older than the reclaim window) is
  // re-claimable so a crashed run can't strand an enrollment.
  lockedAt    DateTime?
  enrolledAt  DateTime                 @default(now())
  completedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  sequence  EmailSequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  recipient EmailRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  // One enrollment per recipient per sequence (idempotent enrollment on send).
  @@unique([sequenceId, recipientId])
  // Primary scheduler index — find due, active enrollments fast.
  @@index([status, nextRunAt])
  @@index([sequenceId])
  @@index([recipientId])
  @@map("email_sequence_enrollment")
}

// ─────────────────────────────────────────────────────────────────────────────
// Production hardening — Suppression list (Do Not Contact).
// Org-scoped, email-keyed. Every campaign + followup send is filtered against
// this list. Populated by: recipient unsubscribe (one-click / footer link),
// hard bounce, and spam complaint. A reply does NOT suppress (it only stops the
// sequence) — replying is engagement, not opt-out.
// ─────────────────────────────────────────────────────────────────────────────

enum SuppressionReason {
  UNSUBSCRIBE
  BOUNCE
  COMPLAINT
  MANUAL
}

model SuppressionList {
  id             String            @id @default(cuid())
  organizationId String
  // Lowercased email. Unique per org so a single address is suppressed once.
  email          String
  reason         SuppressionReason
  // Free-form provenance (e.g. recipientId, campaignId, "webhook:complaint").
  source         String?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, email])
  @@map("suppression_list")
}
